@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":SummaryByDateCommand" as SummaryByDateCommand
participant ":FoodList" as FoodList
participant ":GoalsCommand" as GoalsCommand
participant ":UserInterface" as UI

User -> Bitbites : input "summary d/01-04-2026"
activate Bitbites

Bitbites -> Parser : parse("summary d/01-04-2026")
activate Parser
Parser --> Bitbites : SummaryByDateCommand
deactivate Parser

Bitbites -> SummaryByDateCommand : execute(context)
activate SummaryByDateCommand

alt [* missing or empty date]
  SummaryByDateCommand --> Bitbites : throws BitbitesException
else [* invalid date format or impossible date]
  SummaryByDateCommand --> Bitbites : throws BitbitesException
else [* valid date]
  SummaryByDateCommand -> FoodList : getItemCountByDate(date)
  activate FoodList
  FoodList --> SummaryByDateCommand : count
  deactivate FoodList

  alt [* count == 0]
    SummaryByDateCommand -> SummaryByDateCommand : print "No food items found"
  else [* count > 0]
    SummaryByDateCommand -> GoalsCommand : getDailyCalorieGoal()
    activate GoalsCommand
    GoalsCommand --> SummaryByDateCommand : calorieGoal
    deactivate GoalsCommand

    SummaryByDateCommand -> GoalsCommand : getDailyProteinGoal()
    activate GoalsCommand
    GoalsCommand --> SummaryByDateCommand : proteinGoal
    deactivate GoalsCommand

    SummaryByDateCommand -> FoodList : getSummaryByDate(date)
    activate FoodList
    FoodList --> SummaryByDateCommand : NutritionSummary
    deactivate FoodList

    SummaryByDateCommand -> UI : showSummary(summary, calorieGoal, proteinGoal)
    activate UI
    UI --> SummaryByDateCommand
    deactivate UI
  end
end

SummaryByDateCommand --> Bitbites : false
deactivate SummaryByDateCommand

Bitbites --> User
deactivate Bitbites
@enduml