@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":AddCommand" as AddCommand
participant ":FoodList" as FoodList
participant ":GoalsCommand" as GoalsCommand
participant ":UserInterface" as UI

User -> Bitbites : input "add n/NAME c/CAL p/PROT d/DATE"
activate Bitbites

Bitbites -> Parser : parse(...)
activate Parser
Parser --> Bitbites : AddCommand
deactivate Parser

Bitbites -> AddCommand : execute(context)
activate AddCommand

alt [missing prefix, empty field, or invalid values]
  AddCommand -> UI : print error message
  activate UI
  UI --> AddCommand
  deactivate UI
  AddCommand --> Bitbites : false
else [valid input]
  AddCommand -> AddCommand : extractFields()
  activate AddCommand
  deactivate AddCommand

  AddCommand -> FoodList : addFood(new Food(...))
  activate FoodList
  FoodList --> AddCommand
  deactivate FoodList

  AddCommand -> UI : print(addMessage)
  activate UI
  UI --> AddCommand
  deactivate UI

  AddCommand -> GoalsCommand : showDailyProgress(foodList)
  activate GoalsCommand
  GoalsCommand --> AddCommand
  deactivate GoalsCommand

  AddCommand --> Bitbites : false
end
deactivate AddCommand

Bitbites -> Bitbites : foodStorage.save(foods)
activate Bitbites
deactivate Bitbites

Bitbites --> User
deactivate Bitbites
@enduml
