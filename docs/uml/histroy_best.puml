@startuml history_best
skinparam arrowThickness 1.1
skinparam maxMessageSize 150

participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant "c:HistoryBestCommand" as Cmd
participant "foods:FoodList" as FoodList
participant "goals:GoalsCommand" as Goals
participant "ui:UserInterface" as UI

-> Bitbites : "history /best 3"
activate Bitbites

Bitbites -> Parser : parse("history /best 3")
activate Parser
Parser --> Bitbites : HistoryBestCommand
deactivate Parser

Bitbites -> Cmd : execute(context)
activate Cmd

alt N missing or non-numeric
    Cmd --> Bitbites : throws BitbitesException
else N <= 0
    Cmd --> Bitbites : throws BitbitesException
else valid N
    Cmd -> Goals : getDailyCalorieGoal()
    activate Goals
    Goals --> Cmd : int
    deactivate Goals

    Cmd -> Goals : getDailyProteinGoal()
    activate Goals
    Goals --> Cmd : double
    deactivate Goals

    Cmd -> FoodList : getDaysClosestToGoal(3, calorieGoal)
    activate FoodList
    FoodList --> Cmd : List<NutritionSummary>
    deactivate FoodList

    Cmd -> UI : showHistoryBest(best, 3, calorieGoal, proteinGoal)
    activate UI
    UI --> Cmd
    deactivate UI
end

Cmd --> Bitbites : false
deactivate Cmd
deactivate Bitbites
@enduml