@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":HistoryBestCommand" as HistoryBestCommand
participant ":FoodList" as FoodList
participant ":GoalsCommand" as GoalsCommand
participant ":UserInterface" as UI

User -> Bitbites : input "history /best 3"
activate Bitbites

Bitbites -> Parser : parse("history /best 3")
activate Parser
Parser --> Bitbites : HistoryBestCommand
deactivate Parser

Bitbites -> HistoryBestCommand : execute(context)
activate HistoryBestCommand

alt [* N missing or non-numeric]
  HistoryBestCommand --> Bitbites : throws BitbitesException
else [* N <= 0]
  HistoryBestCommand --> Bitbites : throws BitbitesException
else [* valid N]
  HistoryBestCommand -> GoalsCommand : getDailyCalorieGoal()
  activate GoalsCommand
  GoalsCommand --> HistoryBestCommand : calorieGoal
  deactivate GoalsCommand

  HistoryBestCommand -> GoalsCommand : getDailyProteinGoal()
  activate GoalsCommand
  GoalsCommand --> HistoryBestCommand : proteinGoal
  deactivate GoalsCommand

  HistoryBestCommand -> FoodList : getDaysClosestToGoal(3, calorieGoal)
  activate FoodList
  FoodList --> HistoryBestCommand : List<NutritionSummary>
  deactivate FoodList

  HistoryBestCommand -> UI : showHistoryBest(best, 3, calorieGoal, proteinGoal)
  activate UI
  UI --> HistoryBestCommand
  deactivate UI
end

HistoryBestCommand --> Bitbites : false
deactivate HistoryBestCommand

Bitbites --> User
deactivate Bitbites
@enduml
