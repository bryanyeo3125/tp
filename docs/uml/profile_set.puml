@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":ProfileCommand" as ProfileCommand
participant ":ProfileStorage" as ProfileStorage
participant ":GoalsCommand" as GoalsCommand
participant ":Profile" as Profile

User -> Bitbites : input "profile set g/GENDER a/AGE w/WEIGHT h/HEIGHT"
activate Bitbites

Bitbites -> Parser : parse(...)
activate Parser
Parser --> Bitbites : ProfileCommand
deactivate Parser

Bitbites -> ProfileCommand : execute(context)
activate ProfileCommand

alt [missing prefix or blank input]
  ProfileCommand --> Bitbites : print format error, return false
end

ProfileCommand -> ProfileStorage : loadProfile(name)
activate ProfileStorage
ProfileStorage --> ProfileCommand : existing Profile or null
deactivate ProfileStorage

ProfileCommand -> ProfileCommand : extractValue() for each prefix
activate ProfileCommand
deactivate ProfileCommand

alt [invalid gender]
  ProfileCommand --> Bitbites : print error, return false
else [age/weight/height out of range]
  ProfileCommand --> Bitbites : print error, return false
end

create Profile
ProfileCommand -> Profile : new Profile(name, gender, age, weight, height)
activate Profile
Profile --> ProfileCommand : profile
deactivate Profile

ProfileCommand -> ProfileStorage : saveProfile(profile)
activate ProfileStorage
ProfileStorage --> ProfileCommand
deactivate ProfileStorage

ProfileCommand -> ProfileCommand : showProfile(name)
activate ProfileCommand
deactivate ProfileCommand

ProfileCommand -> GoalsCommand : autoSetGoalsFromBmr(name, profile.getBmr())
activate GoalsCommand
GoalsCommand --> ProfileCommand : daily + weekly calorie goals updated
deactivate GoalsCommand

ProfileCommand --> Bitbites : false
deactivate ProfileCommand

Bitbites --> User
deactivate Bitbites
@enduml
