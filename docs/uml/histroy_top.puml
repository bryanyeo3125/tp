@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":HistoryTopCommand" as HistoryTopCommand
participant ":FoodList" as FoodList
participant ":UserInterface" as UI

User -> Bitbites : input "history /top 3"
activate Bitbites

Bitbites -> Parser : parse("history /top 3")
activate Parser
Parser --> Bitbites : HistoryTopCommand
deactivate Parser

Bitbites -> HistoryTopCommand : execute(context)
activate HistoryTopCommand

alt [N missing or non-numeric]
  HistoryTopCommand --> Bitbites : throws BitbitesException
else [N <= 0]
  HistoryTopCommand --> Bitbites : throws BitbitesException
else [valid N]
  HistoryTopCommand -> FoodList : getTopDaysByCalories(3)
  activate FoodList
  FoodList --> HistoryTopCommand : List<NutritionSummary>
  deactivate FoodList

  HistoryTopCommand -> UI : showHistoryTop(top, 3)
  activate UI
  UI --> HistoryTopCommand
  deactivate UI
end

HistoryTopCommand --> Bitbites : false
deactivate HistoryTopCommand

Bitbites --> User
deactivate Bitbites
@enduml
