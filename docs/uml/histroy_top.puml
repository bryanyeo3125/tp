@startuml history_top
skinparam arrowThickness 1.1
skinparam maxMessageSize 150

participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant "c:HistoryTopCommand" as Cmd
participant "foods:FoodList" as FoodList
participant "ui:UserInterface" as UI

-> Bitbites : "history /top 3"
activate Bitbites

Bitbites -> Parser : parse("history /top 3")
activate Parser
Parser --> Bitbites : HistoryTopCommand
deactivate Parser

Bitbites -> Cmd : execute(context)
activate Cmd

alt N missing or non-numeric
    Cmd --> Bitbites : throws BitbitesException
else N <= 0
    Cmd --> Bitbites : throws BitbitesException
else valid N
    Cmd -> FoodList : getTopDaysByCalories(3)
    activate FoodList
    FoodList --> Cmd : List<NutritionSummary>
    deactivate FoodList

    Cmd -> UI : showHistoryTop(top, 3)
    activate UI
    UI --> Cmd
    deactivate UI
end

Cmd --> Bitbites : false
deactivate Cmd
deactivate Bitbites
@enduml