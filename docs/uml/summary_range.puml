@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":SummaryRangeCommand" as SummaryRangeCommand
participant ":FoodList" as FoodList
participant ":UserInterface" as UI

User -> Bitbites : input "summary from/27-03-2026 to/01-04-2026"
activate Bitbites

Bitbites -> Parser : parse(fullCommand)
activate Parser
Parser --> Bitbites : SummaryRangeCommand
deactivate Parser

Bitbites -> SummaryRangeCommand : execute(context)
activate SummaryRangeCommand

alt [missing from/ or to/]
  SummaryRangeCommand --> Bitbites : throws BitbitesException
else [invalid date format]
  SummaryRangeCommand --> Bitbites : throws BitbitesException
else [fromDate is after toDate]
  SummaryRangeCommand --> Bitbites : throws BitbitesException
else [valid range]
  SummaryRangeCommand -> FoodList : getSummariesInRange(fromDate, toDate)
  activate FoodList
  FoodList --> SummaryRangeCommand : List<NutritionSummary>
  deactivate FoodList

  alt [summaries empty]
    SummaryRangeCommand -> UI : print "No food items found"
    activate UI
    UI --> SummaryRangeCommand
    deactivate UI
  else
    SummaryRangeCommand -> UI : showSummaryRange(summaries, fromDate, toDate)
    activate UI
    UI --> SummaryRangeCommand
    deactivate UI
  end
end

SummaryRangeCommand --> Bitbites : false
deactivate SummaryRangeCommand

Bitbites --> User
deactivate Bitbites
@enduml
