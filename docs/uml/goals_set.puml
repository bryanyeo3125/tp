@startuml
actor User
participant ":Bitbites" as Bitbites
participant ":Parser" as Parser
participant ":GoalsCommand" as GoalsCommand
participant ":GoalsStorage" as GoalsStorage

User -> Bitbites : input "goals set dc/CAL dp/PROT wc/CAL wp/PROT"
activate Bitbites

Bitbites -> Parser : parse(...)
activate Parser
Parser --> Bitbites : GoalsCommand
deactivate Parser

Bitbites -> GoalsCommand : execute(context)
activate GoalsCommand

GoalsCommand -> GoalsStorage : loadGoals(name)
activate GoalsStorage
GoalsStorage --> GoalsCommand : double[] or null
deactivate GoalsStorage

GoalsCommand -> GoalsCommand : loadGoalsIfNeeded()
activate GoalsCommand
deactivate GoalsCommand

alt [no subcommand provided]
  GoalsCommand -> UI : print format reminder
else [no valid prefix found]
  GoalsCommand -> UI : print unknown prefix error
end

GoalsCommand -> GoalsCommand : handleSetGoals(fullCommand)
activate GoalsCommand
deactivate GoalsCommand

loop [for each prefix present]
  GoalsCommand -> GoalsCommand : extractValue()
  activate GoalsCommand
  deactivate GoalsCommand
  alt [value invalid or non-numeric]
    GoalsCommand -> UI : print error
  else [value valid]
    GoalsCommand -> GoalsCommand : update goal field
    activate GoalsCommand
    deactivate GoalsCommand
  end
end

GoalsCommand -> GoalsStorage : saveGoals(name, dc, dp, wc, wp)
activate GoalsStorage
GoalsStorage --> GoalsCommand
deactivate GoalsStorage

GoalsCommand --> Bitbites : false
deactivate GoalsCommand

Bitbites --> User
deactivate Bitbites
@enduml
