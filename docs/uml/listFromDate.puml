@startuml
skinparam arrowThickness 1.1
skinparam maxMessageSize 150

participant ":Parser" as Parser

participant ":FoodList" as FoodList
participant ":Food" as Food

participant ":UserInterface" as UI

-> Parser : handleListFromDate("list d/DATE", foodList, ui)
activate Parser

Parser -> UI : print(BitbitesResponses.listFromDateMessage + date)
activate UI
UI --> Parser
deactivate UI

loop for i = 0 to foodList.size() - 1
    Parser -> FoodList : get(i)
    activate FoodList
    FoodList --> Parser : foodItem
    deactivate FoodList

    Parser -> Food : getDate()
    activate Food
    Food --> Parser : itemDate
    deactivate Food

    opt itemDate.equals(date)
        Parser -> UI : print(count + ". " + foodItem)
        activate UI
        UI --> Parser
        deactivate UI
    end
end

<-- Parser
deactivate Parser
@enduml